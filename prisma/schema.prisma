generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────

enum AdminRole {
  SUPER_ADMIN
  ADMIN
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
}

enum TrainingType {
  ONLINE
  OFFLINE
  EXTERNAL
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum StepType {
  VIDEO
  QUIZ
  PRETEST
  POSTTEST
  DOCUMENT
}

enum AssignmentStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum RegistrationStatus {
  REGISTERED
  ATTENDED
  NO_SHOW
}

enum ResultStatus {
  PASSED
  FAILED
  IN_PROGRESS
}

enum ResultSource {
  ONLINE
  OFFLINE
  EXTERNAL
}

enum CertificateStatus {
  VALID
  REVOKED
}

// ─── Models ──────────────────────────────────────────

model Admin {
  id            String    @id @default(cuid())
  username      String    @unique
  password_hash String
  name          String
  role          AdminRole @default(ADMIN)
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  assignments_created CourseAssignment[] @relation("AssignedByAdmin")

  @@map("admins")
}

model Employee {
  id            String         @id @default(cuid())
  employee_code String         @unique // e.g. "E00001"
  password_hash String
  full_name     String
  position      String         @default("")
  department    String         @default("")
  branch        String         @default("")
  date_of_birth DateTime
  start_date    DateTime       @default(now())
  status        EmployeeStatus @default(ACTIVE)
  created_at    DateTime       @default(now())
  updated_at    DateTime       @updatedAt

  assignments    CourseAssignment[]
  results        TrainingResult[]
  quiz_attempts  QuizAttempt[]
  step_progress  StepProgress[]
  registrations  OfflineRegistration[]
  certificates   Certificate[]

  @@map("employees")
}

model Course {
  id            String       @id @default(cuid())
  code          String       @unique // e.g. "CRS-001"
  title         String
  description   String       @default("")
  training_type TrainingType
  pass_score    Int          @default(80)
  is_mandatory  Boolean      @default(false)
  thumbnail_url String?
  status        CourseStatus @default(DRAFT)
  created_at    DateTime     @default(now())
  updated_at    DateTime     @updatedAt

  steps        CourseStep[]
  sessions     OfflineSession[]
  assignments  CourseAssignment[]
  results      TrainingResult[]
  certificates Certificate[]

  @@map("courses")
}

model CourseStep {
  id                String   @id @default(cuid())
  course_id         String
  step_type         StepType
  title             String
  content_url       String?  // video/document URL on R2
  order_index       Int      @default(0)
  is_required       Boolean  @default(true)
  min_watch_percent Int      @default(95) // for VIDEO type
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  course    Course         @relation(fields: [course_id], references: [id], onDelete: Cascade)
  questions Question[]
  progress  StepProgress[]
  attempts  QuizAttempt[]

  @@map("course_steps")
}

model Question {
  id             String   @id @default(cuid())
  step_id        String
  question_text  String
  options        Json     // ["option A", "option B", ...]
  correct_answer Int      // index of correct option
  order_num      Int      @default(0)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  step CourseStep @relation(fields: [step_id], references: [id], onDelete: Cascade)

  @@map("questions")
}

model StepProgress {
  id            String   @id @default(cuid())
  employee_id   String
  step_id       String
  completed     Boolean  @default(false)
  watch_percent Float    @default(0) // for VIDEO type
  last_position Float    @default(0) // last video position in seconds
  updated_at    DateTime @updatedAt

  employee Employee   @relation(fields: [employee_id], references: [id], onDelete: Cascade)
  step     CourseStep @relation(fields: [step_id], references: [id], onDelete: Cascade)

  @@unique([employee_id, step_id])
  @@map("step_progress")
}

model QuizAttempt {
  id          String   @id @default(cuid())
  employee_id String
  step_id     String
  score       Float
  passed      Boolean
  attempt_no  Int
  answers     Json     // submitted answers
  created_at  DateTime @default(now())

  employee Employee   @relation(fields: [employee_id], references: [id], onDelete: Cascade)
  step     CourseStep @relation(fields: [step_id], references: [id], onDelete: Cascade)

  @@map("quiz_attempts")
}

model CourseAssignment {
  id           String           @id @default(cuid())
  employee_id  String
  course_id    String
  assigned_by  String?          // Admin ID
  assigned_at  DateTime         @default(now())
  due_date     DateTime?
  status       AssignmentStatus @default(NOT_STARTED)

  employee Employee @relation(fields: [employee_id], references: [id], onDelete: Cascade)
  course   Course   @relation(fields: [course_id], references: [id], onDelete: Cascade)
  admin    Admin?   @relation("AssignedByAdmin", fields: [assigned_by], references: [id])

  @@unique([employee_id, course_id])
  @@map("course_assignments")
}

model OfflineSession {
  id           String   @id @default(cuid())
  course_id    String
  session_date DateTime
  location     String   @default("")
  capacity     Int      @default(30)
  trainer_name String   @default("")
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  course        Course                @relation(fields: [course_id], references: [id], onDelete: Cascade)
  registrations OfflineRegistration[]

  @@map("offline_sessions")
}

model OfflineRegistration {
  id            String             @id @default(cuid())
  employee_id   String
  session_id    String
  status        RegistrationStatus @default(REGISTERED)
  registered_at DateTime           @default(now())

  employee Employee       @relation(fields: [employee_id], references: [id], onDelete: Cascade)
  session  OfflineSession @relation(fields: [session_id], references: [id], onDelete: Cascade)

  @@unique([employee_id, session_id])
  @@map("offline_registrations")
}

model TrainingResult {
  id           String       @id @default(cuid())
  employee_id  String
  course_id    String
  status       ResultStatus @default(IN_PROGRESS)
  score        Float?
  source       ResultSource
  completed_at DateTime?
  created_at   DateTime     @default(now())

  employee Employee @relation(fields: [employee_id], references: [id], onDelete: Cascade)
  course   Course   @relation(fields: [course_id], references: [id], onDelete: Cascade)

  @@unique([employee_id, course_id, source])
  @@map("training_results")
}

model Certificate {
  id             String            @id @default(cuid())
  certificate_no String            @unique // e.g. "MKPI-2026-00001"
  employee_id    String
  course_id      String
  score          Float
  issued_at      DateTime          @default(now())
  status         CertificateStatus @default(VALID)
  pdf_url        String?
  revoked_at     DateTime?
  revoked_reason String?

  employee Employee @relation(fields: [employee_id], references: [id], onDelete: Cascade)
  course   Course   @relation(fields: [course_id], references: [id], onDelete: Cascade)

  @@map("certificates")
}
