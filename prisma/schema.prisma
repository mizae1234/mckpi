generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────

enum AdminRole {
  SUPER_ADMIN
  ADMIN
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
}

enum TrainingType {
  ONLINE
  OFFLINE
  EXTERNAL
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  COMPLETED
  ARCHIVED
}

enum StepType {
  VIDEO
  QUIZ
  PRETEST
  POSTTEST
  DOCUMENT
}

enum AssignmentStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum RegistrationStatus {
  REGISTERED
  WAITLISTED
  ATTENDED
  CANCELLED
  NO_SHOW
}

enum ResultStatus {
  PASSED
  FAILED
  IN_PROGRESS
}

enum ResultSource {
  ONLINE
  OFFLINE
  EXTERNAL
  IMPORT
}

enum CertificateStatus {
  VALID
  REVOKED
}

// ─── Models ──────────────────────────────────────────

model Admin {
  id            String    @id @default(cuid())
  username      String    @unique
  passwordHash String
  name          String
  role          AdminRole @default(ADMIN)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  assignmentsCreated CourseAssignment[] @relation("AssignedByAdmin")
}

model Employee {
  id             String         @id @default(cuid())
  employeeCode   String         @unique // e.g. "E00001"
  passwordHash   String
  fullName       String
  positionCode   String?
  departmentCode String?
  branchCode     String?
  dateOfBirth    DateTime
  startDate      DateTime       @default(now())
  status         EmployeeStatus @default(ACTIVE)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  assignments    CourseAssignment[]
  results        TrainingResult[]
  quizAttempts   QuizAttempt[]
  stepProgress   StepProgress[]
  registrations  OfflineRegistration[]
  certificates   Certificate[]
  branch         Branch?        @relation(fields: [branchCode], references: [code])
}

model Branch {
  id         String   @id @default(cuid())
  code       String   @unique
  name       String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employees Employee[]
}

model Course {
  id            String       @id @default(cuid())
  code          String       @unique // e.g. "CRS-001"
  title         String
  description   String       @default("")
  trainingType TrainingType
  passScore    Int          @default(80)
  isMandatory  Boolean      @default(false)
  creditHours  Float        @default(0) // ชั่วโมงอบรม/เครดิต
  thumbnailUrl String?
  status        CourseStatus @default(DRAFT)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  steps        CourseStep[]
  documents    CourseDocument[]
  sessions     OfflineSession[]
  assignments  CourseAssignment[]
  results      TrainingResult[]
  certificates Certificate[]
  kpis         KpiCourse[]
}

model CourseStep {
  id                String   @id @default(cuid())
  courseId         String
  stepType         StepType
  title             String
  contentUrl       String?  // video/document URL on R2
  contentFilename  String?  // original uploaded filename
  orderIndex       Int      @default(0)
  isRequired       Boolean  @default(true)
  minWatchPercent Int      @default(95) // for VIDEO type
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  course    Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  questions Question[]
  progress  StepProgress[]
  attempts  QuizAttempt[]
}

model CourseDocument {
  id         String   @id @default(cuid())
  courseId  String
  filename   String   // original filename
  fileUrl   String   // R2 public URL
  fileSize  Int      @default(0) // bytes
  fileType  String   @default("") // MIME type
  createdAt DateTime @default(now())

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model Question {
  id               String          @id @default(cuid())
  stepId           String
  questionText     String
  options          Json            // ["option A", "option B", ...]
  correctAnswer    Int             // index of correct option
  orderNum         Int             @default(0)
  masterQuestionId String?         // track which master question this was copied from
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  step           CourseStep       @relation(fields: [stepId], references: [id], onDelete: Cascade)
  masterQuestion MasterQuestion?  @relation(fields: [masterQuestionId], references: [id], onDelete: SetNull)
}

model QuestionSet {
  id          String   @id @default(cuid())
  name        String
  description String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  questions MasterQuestion[]
}

model MasterQuestion {
  id            String   @id @default(cuid())
  questionSetId String
  questionText  String
  options       Json     // ["ตัวเลือก A", "ตัวเลือก B", ...]
  correctAnswer Int      // index of correct option
  orderNum      Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  questionSet    QuestionSet @relation(fields: [questionSetId], references: [id], onDelete: Cascade)
  copiedQuestions Question[] // questions that were copied from this master
}

model StepProgress {
  id            String   @id @default(cuid())
  employeeId   String
  stepId       String
  completed     Boolean  @default(false)
  watchPercent Float    @default(0) // for VIDEO type
  lastPosition Float    @default(0) // last video position in seconds
  updatedAt    DateTime @updatedAt

  employee Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  step     CourseStep @relation(fields: [stepId], references: [id], onDelete: Cascade)

  @@unique([employeeId, stepId])
}

model QuizAttempt {
  id          String   @id @default(cuid())
  employeeId String
  stepId     String
  score       Float
  passed      Boolean
  attemptNo  Int
  answers     Json     // submitted answers
  createdAt  DateTime @default(now())

  employee Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  step     CourseStep @relation(fields: [stepId], references: [id], onDelete: Cascade)
}

model CourseAssignment {
  id           String           @id @default(cuid())
  employeeId  String
  courseId    String
  assignedBy  String?          // Admin ID
  assignedAt  DateTime         @default(now())
  dueDate     DateTime?
  status       AssignmentStatus @default(NOT_STARTED)

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  course   Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  admin    Admin?   @relation("AssignedByAdmin", fields: [assignedBy], references: [id])

  @@unique([employeeId, courseId])
}

model OfflineSession {
  id                  String   @id @default(cuid())
  courseId            String
  sessionDate         DateTime
  sessionEndDate      DateTime?
  registrationEndDate DateTime?
  location            String   @default("")
  capacity            Int      @default(30)
  waitlistCapacity    Int      @default(0)
  trainerName         String   @default("")
  meetingUrl          String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  course        Course                @relation(fields: [courseId], references: [id], onDelete: Cascade)
  registrations OfflineRegistration[]
}

model OfflineRegistration {
  id            String             @id @default(cuid())
  employeeId   String
  sessionId    String
  status        RegistrationStatus @default(REGISTERED)
  registeredAt DateTime           @default(now())

  employee Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  session  OfflineSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([employeeId, sessionId])
}

model TrainingResult {
  id           String       @id @default(cuid())
  employeeId  String
  courseId    String
  status       ResultStatus @default(IN_PROGRESS)
  score        Float?
  pretestScore Float?
  posttestScore Float?
  source       ResultSource
  completedAt DateTime?
  createdAt   DateTime     @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  course   Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([employeeId, courseId, source])
}

model Certificate {
  id             String            @id @default(cuid())
  certificateNo String            @unique // e.g. "MKPI-2026-00001"
  employeeId    String
  courseId      String
  score          Float
  issuedAt      DateTime          @default(now())
  status         CertificateStatus @default(VALID)
  pdfUrl        String?
  revokedAt     DateTime?
  revokedReason String?

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  course   Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model Kpi {
  id          String     @id @default(cuid())
  code        String     // e.g. "KPI-2026-001"
  name        String     // e.g. "ความปลอดภัยในการทำงาน"
  target      String     @default("") // เป้าหมาย
  year        Int        // e.g. 2026
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  courses     KpiCourse[]

  @@unique([code, year])
}

model KpiCourse {
  id        String @id @default(cuid())
  kpiId     String
  courseId  String

  kpi       Kpi    @relation(fields: [kpiId], references: [id], onDelete: Cascade)
  course    Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([kpiId, courseId])
}
